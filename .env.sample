# Database
DATABASE_URL=postgresql://user:password@localhost:5432/surfapp

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key

# Cron authentication
CRON_SECRET=your-cron-secret

# WorldTides API (optional fallback)
WORLDTIDES_API_KEY=your-worldtides-key

# Mapbox (for meteorological map)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...your-mapbox-public-token
NEXT_PUBLIC_ENABLE_MAP=false
